# ─────────────────────────────────────────
# AI AGENT PORTFOLIO — Environment Variables
# ─────────────────────────────────────────
# Copy this file and rename it to .env
# Fill in your actual API keys
# NEVER commit your real .env to GitHub

# ─── OpenAI ───────────────────────────────
# Get your key from: platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ─── LangSmith — Observability ────────────
# Get your key from: smith.langchain.com
# If your account is on EU servers use:
# https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=ai-agent-portfolio
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── Tavily — Web Search ──────────────────
# Get your key from: app.tavily.com
# Free tier: 1000 searches/month
TAVILY_API_KEY=your_tavily_key_here

